## SECTION 3 — UI Consistency Rules

### Color
```tsx
// Primary color — always CSS var driven
<div className="bg-primary text-white" />          // ✅
<div style={{ backgroundColor: '#1152D4' }} />      // ❌ breaks theming

// Blue alias — use only for non-themed DEVCON blue (organizer nav, links, fallback)
<div className="bg-blue" />                         // ✅ organizer sidebar
<div className="bg-primary" />                      // ✅ member sidebar

// Slate scale — only 50/100/200/300/400/500/700/900
<p className="text-slate-700" />                    // ✅
<p className="text-slate-600" />                    // ❌ doesn't exist
```

### Typography — two valid tiers, MD3 preferred for new work
```tsx
// New components — use MD3 tokens
<h1 className="text-md3-headline-lg font-semibold font-proxima" />
<p className="text-md3-body-md font-proxima" />

// Existing components — do not change legacy scale unless reworking
<h1 className="text-2xl font-semibold" />  // ✅ legacy — leave it
```

### Icons
```tsx
// Always solar-icon-set outline variant
import { HomeOutline, StarOutline } from 'solar-icon-set'

// In a colored container
<div className="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
  <HomeOutline className="w-5 h-5 text-primary" />
</div>

// Points star — special case: outline with gold fill
<StarOutline className="w-5 h-5 fill-gold text-gold" />
```

### Animation
```tsx
// Always import — never redefine
import { fadeUp, staggerContainer, cardItem } from '@/lib/animation'

// Page wrapper
<motion.div variants={fadeUp} initial="hidden" animate="visible">

// List section with stagger
<motion.div variants={staggerContainer} initial="hidden" animate="visible">
  {items.map(item => (
    <motion.div key={item.id} variants={cardItem}>
      <ItemCard item={item} />
    </motion.div>
  ))}
</motion.div>

// whileTap spring values — do not deviate
// Card: scale: 0.97, stiffness: 400, damping: 25
// Button: scale: 0.95, stiffness: 400, damping: 25
// Nav item: scale: 0.88, stiffness: 400, damping: 20
```

### PROMOTED badge rule
```tsx
// 2nd job listing and 2nd Tech news post always get the orange badge
// This is driven by is_promoted = true in the DB — do not hardcode position
// Verify the data: Sui Foundation job and 2nd Tech news post must have is_promoted = true
<PromotedBadge />  // orange #F97316 — reuse this component, never inline
```

